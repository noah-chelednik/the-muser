# The Muser — Environment Configuration
# Copy this to .env and edit as needed.
# All values shown are defaults — only set what you want to change.

# =====================================================================
# LLM Provider
# =====================================================================
# Options: local (Ollama only), hybrid (free cloud + local), cloud, anthropic
MUSER_LLM_MODE=local

# Ollama (always available as local fallback)
MUSER_OLLAMA_MODEL=qwen3:30b-a3b
OLLAMA_HOST=http://localhost:11434

# Free cloud API keys (optional — enables faster inference)
# GROQ_API_KEY=
# GOOGLE_API_KEY=
# CEREBRAS_API_KEY=

# Anthropic Claude (optional, paid)
# ANTHROPIC_API_KEY=

# =====================================================================
# ACE-Step Music Generation
# =====================================================================
MUSER_ACESTEP_VERSION=v15
MUSER_ACESTEP_INFER_STEP=50
MUSER_ACESTEP_GUIDANCE=4.0
MUSER_BEST_OF_N=2
# MUSER_ACESTEP_API_URL=          # Set for REST API mode

# =====================================================================
# DiffSinger Vocal Synthesis
# =====================================================================
# Default: griffin-lim (safe, open). Set to fish-hifigan for better quality.
# nsf-hifigan requires MUSER_VOCODER_NC_ACK=true (CC-BY-NC-SA 4.0).
MUSER_DIFFSINGER_VOCODER=griffin-lim
# MUSER_VOCODER_NC_ACK=false

# =====================================================================
# GPU & Audio
# =====================================================================
MUSER_VRAM_GB=24
MUSER_SAMPLE_RATE=44100
MUSER_TARGET_LUFS=-14
MUSER_MP3_BITRATE=320k

# =====================================================================
# Voice Feminization
# =====================================================================
# praat_cli (default, GPL-safe) or parselmouth (GPL v3, user opts in)
MUSER_FEMINIZE_BACKEND=praat_cli

# =====================================================================
# Curation & Export
# =====================================================================
# MUSER_ARTIST_NAME=
# MUSER_COPYRIGHT_HOLDER=
# MUSER_RELEASE_YEAR=2026

# =====================================================================
# Tool Paths (auto-detected, override if needed)
# =====================================================================
# MUSER_LILYPOND_PATH=lilypond
# MUSER_FLUIDSYNTH_PATH=fluidsynth
# MUSER_SFIZZ_PATH=sfizz_render
